@model MvcMovie.Models.Movie

@{
    ViewData["Title"] = "Create Movie";
}

<h1>Create New Movie</h1>

<hr />
<div class="row">
    <div class="col-md-6">
        <form asp-action="Create">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <div class="form-group mb-3">
                <label asp-for="Title" class="control-label fw-bold"></label>
                <input asp-for="Title" class="form-control" placeholder="Enter movie title" />
                <span asp-validation-for="Title" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="ReleaseDate" class="control-label fw-bold"></label>
                <input asp-for="ReleaseDate" class="form-control" type="date" />
                <span asp-validation-for="ReleaseDate" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="Genre" class="control-label fw-bold"></label>
                <input asp-for="Genre" class="form-control" placeholder="e.g., Comedy, Drama, Sci-Fi" />
                <span asp-validation-for="Genre" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="Price" class="control-label fw-bold"></label>
                <input asp-for="Price" class="form-control" type="number" step="0.01" min="1" max="100" />
                <span asp-validation-for="Price" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="Rating" class="control-label fw-bold"></label>
                <input asp-for="Rating" class="form-control" placeholder="e.g., G, PG, PG-13, R" maxlength="5" />
                <span asp-validation-for="Rating" class="text-danger"></span>
                <small class="form-text text-muted">Maximum 5 characters</small>
            </div>

            <div class="form-group">
                <input type="submit" value="Create" class="btn btn-primary" />
                <a asp-action="Index" class="btn btn-secondary">Back to List</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}